NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for machine callers (n8n, automations) hitting the REST API
# via the `x-api-key` header. Generate a long random value; unset = disabled.
N8N_API_KEY=

# Per-source shared secrets for the inbound webhook endpoints under
# /api/webhooks/*. Each is unset = disabled (that endpoint 501s) until set.
GOOGLE_DRIVE_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET=
AI_AGENTS_WEBHOOK_SECRET=

# Google OAuth 2.0 client for the Drive/Sheets/Docs sync framework.
# See README > Google OAuth setup for how to create these in Google Cloud
# Console. GOOGLE_OAUTH_CLIENT_SECRET is server-only — never expose it to
# the frontend (it is never read outside src/server/**).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match an "Authorized redirect URI" on the OAuth client, e.g.
# https://your-app.example.com/api/integrations/google/oauth/callback
# Optional in development — falls back to deriving one from the request.
GOOGLE_OAUTH_REDIRECT_URI=
