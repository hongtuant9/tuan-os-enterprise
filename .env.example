NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public, browser-facing base URL for this deployment, e.g.
# https://app.tamcocexperience.com (no trailing slash). Used to build
# user-facing redirects (OAuth callbacks, etc.) instead of deriving one from
# the incoming request, which behind a reverse proxy (Coolify/Traefik)
# resolves to the internal container hostname rather than the public domain.
# Set APP_URL for server-only use; NEXT_PUBLIC_APP_URL is its
# client-exposed fallback. At least one should be set in production.
APP_URL=
NEXT_PUBLIC_APP_URL=

# Shared secret for machine callers (n8n, automations) hitting the REST API
# via the `x-api-key` header. Generate a long random value; unset = disabled.
N8N_API_KEY=

# Per-source shared secrets for the inbound webhook endpoints under
# /api/webhooks/*. Each is unset = disabled (that endpoint 501s) until set.
GOOGLE_DRIVE_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET=
AI_AGENTS_WEBHOOK_SECRET=

# Google OAuth 2.0 client for the Drive/Sheets/Docs sync framework.
# See README > Google OAuth setup for how to create these in Google Cloud
# Console. GOOGLE_OAUTH_CLIENT_SECRET is server-only — never expose it to
# the frontend (it is never read outside src/server/**).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match an "Authorized redirect URI" on the OAuth client, e.g.
# https://your-app.example.com/api/integrations/google/oauth/callback
# Optional — falls back to `${APP_URL || NEXT_PUBLIC_APP_URL}/api/integrations/google/oauth/callback`.
GOOGLE_OAUTH_REDIRECT_URI=

# AI Booking, Concierge & Experience Agent — Private Pilot.
# Keep all outbound connectors and KiotViet writes disabled until migration,
# Safety Gate, idempotency and read-back verification have passed acceptance.
AI_RECEPTIONIST_MODE=SIMULATION
AI_PILOT_ALLOWLIST_ENABLED=true
# Comma-separated external conversation IDs allowed during Private Pilot.
AI_PILOT_ALLOWED_CONVERSATION_IDS=
AI_PILOT_KNOWLEDGE_CAPTURE_ENABLED=true
AI_PILOT_OUTBOUND_ENABLED=false
AI_PILOT_KIOTVIET_WRITE_ENABLED=false
KIOTVIET_HOTEL_DIRECT_BOOKING_AUTO_CREATE_ENABLED=false

# KiotViet Hotel server-side integration. Never expose the key with NEXT_PUBLIC_*.
KIOTVIET_HOTEL_API_BASE_URL=https://api-integration-hotel.kiotviet.vn
KIOTVIET_HOTEL_PUBLIC_API_KEY=
KIOTVIET_HOTEL_WEBHOOK_SECRET=

# Concierge and experience capabilities remain disabled until their source
# data, partner confirmations, offer rules and rollback paths are approved.
AI_PREARRIVAL_ENABLED=false
AI_TAXI_AUTO_CONFIRM_ENABLED=false
AI_EXPERIENCE_CROSS_SELL_ENABLED=false
AI_VOUCHER_SEND_ENABLED=false
